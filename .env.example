# Copy to .env for local runs (.env is gitignored).
# In GitHub Actions, set these as repo Secrets instead — the workflow reads them
# from `secrets.*`, not from this file.

# --- Required ----------------------------------------------------------------

# Discord webhook URL. Channel settings → Integrations → Webhooks → New Webhook.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/REPLACE_ME

# LLM API key — only the one matching your config.yaml `llm.provider` is needed.
GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GROQ_API_KEY=

# --- Recommended -------------------------------------------------------------

# Your email. NCBI asks for one (no signup) and gives you a higher PubMed rate
# limit. Also reused as the Unpaywall identifier unless UNPAYWALL_EMAIL is set.
NCBI_EMAIL=you@example.com

# --- Optional ----------------------------------------------------------------

# Free NCBI API key (https://www.ncbi.nlm.nih.gov/account/) — bumps the PubMed
# rate limit from 3 req/s to 10 req/s. Only matters if you have many sources.
# NCBI_API_KEY=

# Override the email sent to Unpaywall (defaults to NCBI_EMAIL).
# UNPAYWALL_EMAIL=
